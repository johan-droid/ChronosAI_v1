# Copy this file to .env (or .env.local) and replace values with your secrets.

# MongoDB connection URI used by backend/config/db.js
MONGO_URI=mongodb://localhost:27017/chronosai

# JWT secret used for auth token signing/verifying
JWT_SECRET=very_secure_random_string

# Google OAuth client config used in auth/calendar controllers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/callback
GOOGLE_AUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Frontend origin used to build links and CORS redirects
FRONTEND_URL=http://localhost:5173

# Resend email service key (optional, emails disabled if empty)
RESEND_API_KEY=your_resend_api_key
SENDER_EMAIL=no-reply@yourdomain.com

# Server port
PORT=5000

# Optional: runtime mode
NODE_ENV=development

RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=587
RESEND_SMTP_SECURE=false
RESEND_SMTP_USER=apikey
RESEND_SMTP_PASS=re_xxxxxxxxx
SENDER_EMAIL=onboarding@resend.dev