# Copy this file to .env (or .env.local) and replace values with your secrets.

MONGO_URI=mongodb://localhost:27017/chronosai
JWT_SECRET=very_secure_random_string
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/callback
GOOGLE_AUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
PORT=5000
